CREATE TABLE customers(
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(50),
    surname VARCHAR(50),
    street VARCHAR(100),
    payment_type VARCHAR(30),
    is_payment BOOLEAN
);

CREATE TABLE orders(
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(50),
    price DECIMAL(10,2),
    weight INT,
    id_customers INT,
    FOREIGN KEY(id_customers)
    REFERENCES customers(id)
);
