<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coffi</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav>
        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">Orders</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Coffe types</a></li>
        </ul>
    </nav>

    <header>
        <div class="logo-box">
            <h1>Coffi ☕</h1>
        </div>
    </header>

    <main>

        <section class="calculator">
            <h2>Calculate your order</h2>

            <div class="form-box">
                <label>Enter coffe name</label>
                <input type="text" placeholder="{value}">

                <label>Enter coffe weight</label>
                <input type="number" placeholder="{value}">

                <div class="result">
                    <button>Process</button>
                    <span>Order price:</span>
                </div>
            </div>
        </section>

        <aside class="menu">
            <h3>Menu</h3>
            <ul>
                <li>Arabica</li>
                <li>Robusta</li>
                <li>Green</li>
                <li>Mocha</li>
                <li>No-caffine</li>
            </ul>

            <button class="order-btn">Order it!</button>
        </aside>

    </main>

    <footer>
        <p>© 2024. Coffi</p>
    </footer>

</body>
</html>

